-- =============================================================================
--  APTRANSCO Internship Portal — AISHE College Database Schema
--  PostgreSQL
--  Run this once in your existing database before importing data.
-- =============================================================================


-- -----------------------------------------------------------------------------
-- 1. AISHE COLLEGES TABLE
-- -----------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS aishe_colleges (

    id               SERIAL          PRIMARY KEY,

    -- Core identity (from AISHE dataset)
    aishe_code       VARCHAR(20)     NOT NULL UNIQUE,   -- e.g. "C-12345"
    college_name     TEXT            NOT NULL,

    -- Parent university / affiliation
    university_name  TEXT,
    university_code  VARCHAR(20),

    -- Location
    state_name       VARCHAR(100),
    district_name    VARCHAR(100),
    city             VARCHAR(100),
    pincode          VARCHAR(10),

    -- Classification (matches frontend dropdown values)
    -- IIT | NIT | IIIT | CENTRAL | STATE_UNIV | DEEMED | OTHER
    college_type     VARCHAR(20)     DEFAULT 'OTHER',

    -- Management type (Government / Government Aided / Private Unaided / etc.)
    management_type  VARCHAR(60),

    -- Programme types offered (stored as simple text for display)
    programmes       TEXT,           -- e.g. "B.Tech, M.Tech, MBA"

    -- NIRF ranking if available
    nirf_rank        INTEGER,

    -- Active flag — set to false to hide a college without deleting
    is_active        BOOLEAN         DEFAULT TRUE,

    -- Audit
    created_at       TIMESTAMPTZ     DEFAULT NOW(),
    updated_at       TIMESTAMPTZ     DEFAULT NOW()
);


-- -----------------------------------------------------------------------------
-- 2. INDEXES — critical for fast full-text search on 50,000+ rows
-- -----------------------------------------------------------------------------

-- Primary search index: trigram GIN index on college_name
-- Enables fast ILIKE '%query%' searches without full table scan
-- Requires: CREATE EXTENSION IF NOT EXISTS pg_trgm;
CREATE EXTENSION IF NOT EXISTS pg_trgm;

CREATE INDEX IF NOT EXISTS idx_aishe_college_name_trgm
    ON aishe_colleges
    USING GIN (college_name gin_trgm_ops);

-- Also index university_name for combined searches
CREATE INDEX IF NOT EXISTS idx_aishe_university_name_trgm
    ON aishe_colleges
    USING GIN (university_name gin_trgm_ops);

-- B-tree indexes for equality filter columns (state, type)
CREATE INDEX IF NOT EXISTS idx_aishe_state
    ON aishe_colleges (state_name);

CREATE INDEX IF NOT EXISTS idx_aishe_type
    ON aishe_colleges (college_type);

-- Composite index for the most common combined filter
CREATE INDEX IF NOT EXISTS idx_aishe_state_type
    ON aishe_colleges (state_name, college_type);

-- Index on aishe_code for fast lookups by code
CREATE INDEX IF NOT EXISTS idx_aishe_code
    ON aishe_colleges (aishe_code);

-- Partial index for active colleges only (most queries only touch active rows)
CREATE INDEX IF NOT EXISTS idx_aishe_active
    ON aishe_colleges (id)
    WHERE is_active = TRUE;


-- -----------------------------------------------------------------------------
-- 3. AUTO-UPDATE updated_at TRIGGER
-- -----------------------------------------------------------------------------
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_aishe_updated_at ON aishe_colleges;

CREATE TRIGGER trg_aishe_updated_at
    BEFORE UPDATE ON aishe_colleges
    FOR EACH ROW
    EXECUTE FUNCTION set_updated_at();


