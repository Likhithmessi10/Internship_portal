-- -----------------------------------------------------------------------------
-- 5. HOW TO IMPORT THE FULL AISHE DATASET
-- -----------------------------------------------------------------------------
--
--  Step 1: Download the institution-level data from:
--          https://aishe.gov.in  →  Data  →  AISHE Data  →  All Institutions (CSV / Excel)
--
--  Step 2: Save as aishe_colleges.csv with headers matching these columns:
--          aishe_code, college_name, university_name, university_code,
--          state_name, district_name, city, pincode, college_type,
--          management_type, programmes, nirf_rank
--
--  Step 3: Import using psql:
--
--          \COPY aishe_colleges (aishe_code, college_name, university_name,
--              university_code, state_name, district_name, city, pincode,
--              college_type, management_type, programmes, nirf_rank)
--          FROM '/path/to/aishe_colleges.csv'
--          WITH (FORMAT csv, HEADER true, NULL '');
--
--  Step 4: Verify row count:
--          SELECT COUNT(*) FROM aishe_colleges;
--          -- Expected: ~40,000 – 55,000 rows
--
--  Step 5: Check indexes are used (run EXPLAIN ANALYZE on a sample query):
--          EXPLAIN ANALYZE
--          SELECT * FROM aishe_colleges
--          WHERE college_name ILIKE '%venkateswara%' AND is_active = TRUE
--          LIMIT 20;
--          -- Should show "Bitmap Index Scan on idx_aishe_college_name_trgm"
--
-- =============================================================================