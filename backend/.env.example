# ===========================================
# APTRANSCO Internship Portal - Backend
# Environment Configuration Template
# ===========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -------------------------------------------
# Server Configuration
# -------------------------------------------
PORT=5001
NODE_ENV=development

# -------------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/aptransco?schema=public"

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# CRITICAL: Generate a strong random secret for production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token Expiry (access token)
JWT_EXPIRY=2h

# JWT Refresh Token Expiry
JWT_REFRESH_EXPIRY=7d

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# Comma-separated list of allowed origins (no trailing slash)
# Production: Use your actual domain(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# -------------------------------------------
# File Upload Configuration
# -------------------------------------------
MAX_FILE_SIZE=5242880
# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/jpg

# -------------------------------------------
# ClamAV Configuration (Optional - for malware scanning)
# -------------------------------------------
# Set to 'true' to enable malware scanning on uploads
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Socket path alternative (if using Unix socket)
# CLAMAV_SOCKET_PATH=/var/run/clamav/clamd.ctl

# -------------------------------------------
# Email Configuration (for OTP/notifications)
# -------------------------------------------
# The API endpoints for the APTRANSCO proprietary email sending service
EMAIL_SERVICE_URL=https://aptrservice.aptransco.gov.in/api/noreply
EMAIL_SERVICE_ATTACHMENT_URL=https://aptrservice.aptransco.gov.in/api/noreplyattachment

# -------------------------------------------
# Security Configuration
# -------------------------------------------
# Minimum password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
# Options: 'dev', 'combined', 'common', 'short', 'tiny'
MORGAN_LOG_FORMAT=dev
# Set to 'true' to log to file instead of console
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log

# -------------------------------------------
# Audit Log Configuration
# -------------------------------------------
# Retention period in days (0 = infinite)
AUDIT_LOG_RETENTION_DAYS=365
