generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  STUDENT
  HOD
  COMMITTEE_MEMBER
  MENTOR
  CE_PRTI
  ADMIN
}

enum ApplicationStatus {
  SUBMITTED
  SHORTLISTED
  UNDER_COMMITTEE_REVIEW
  SELECTED            // HOD final selection (was APPROVED)
  APPROVED            // Legacy — kept for backward compatibility
  REPORTED            // Student physically reported to PRTI; roll number generated here (MONETARY)
  REJECTED
  WAITLISTED
  DOCUMENTS_PENDING   // NON_STIPEND: docs upload unlocked after SELECTED
  DOCUMENTS_VERIFIED  // NON_STIPEND: PRTI verified all docs
  HIRED               // All joining formalities complete; roll number generated for NON_STIPEND
  ONGOING
  COMPLETED
}

enum InternshipCategory {
  MONETARY
  CERTIFICATE_ONLY
}

enum CollegeCategory {
  IIT
  NIT
  IIIT
  CENTRAL
  STATE
  PRIVATE
  OTHER
}

enum ScoreCriteria {
  ACADEMIC_MERIT
  SOP_QUALITY
  DISCIPLINE_RELEVANCE
}

enum Decision {
  YES
  NO
}

// ==========================================
// MODELS
// ==========================================
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  role       Role     @default(STUDENT)
  department String?
  phone          String?  @map("phone_number")
  photoUrl       String?
  designation    String?  // job title / designation (for mentors)
  mentorField    String?  // field name this mentor handles (for auto-assignment)
  mentorLocation String?  // location this mentor is based at (for auto-assignment)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studentProfile StudentProfile?
  mentoredApps   Application[]   @relation("MentorApps")
  workAssignments WorkAssignment[] @relation("MentorWork")
  mentoredPs     InternshipDepartmentProblemStatement[] @relation("PsMentor")
}

model StudentProfile {
  id                String          @id @default(uuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber        String?         @unique
  collegeRollNumber String?
  fullName          String
  phone             String
  dob               DateTime
  address           String
  aadhaarNumber     String          @unique @map("aadhar")
  collegeName       String
  collegeCode       String?
  university        String
  degree            String
  branch            String
  yearOfStudy       Int
  cgpa              Float
  collegeCategory   CollegeCategory
  nirfRanking       Int?
  hasExperience     Boolean         @default(false)
  hasProjects       Boolean         @default(false)
  hasCertifications Boolean         @default(false)
  experienceDesc    String?
  projectsDesc      String?
  certificationsDesc String?
  skills            String?
  photoUrl          String?
  linkedinUrl       String?
  githubUrl         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  applications Application[]
  workAssignments WorkAssignment[] @relation("InternWork")
  workLogs        WorkLog[]

  @@index([userId])
  @@index([collegeName])
}

// ── Master configuration for NON_STIPEND (Learning) internships ──────────────

model DepartmentMaster {
  id         String        @id @default(uuid())
  name       String        @unique  // e.g., "SLDC"
  code       String        @unique  // short code, e.g., "SLDC"
  deptNumber Int           @unique  // sequential, immutable — used in roll number
  isActive   Boolean       @default(true)
  createdBy  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  fields     FieldMaster[]
}

// Append-only: fieldNumber is immutable once assigned — roll number stability depends on it
model FieldMaster {
  id          String           @id @default(uuid())
  departmentId String
  fieldCode   String           @unique  // e.g., "SLDC-SCADA-001", immutable
  fieldName   String
  fieldNumber Int              // sequential within dept, IMMUTABLE — used in roll number
  specializations Json?        @default("[]") // fixed target branches for this field
  locations   Json?            @default("[]") // default posting locations for this field
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  department       DepartmentMaster @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  internshipFields InternshipField[]

  @@unique([departmentId, fieldNumber])
  @@index([departmentId])
}

model InternshipBatch {
  id          String       @id @default(uuid())
  title       String       // e.g. "Summer Internships 2026"
  description String?
  createdBy   String?      // PRTI member email/id
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  internships Internship[]
}

model Internship {
  id                   String    @id @default(uuid())
  batchId              String?
  title                String
  department           String
  description          String
  roles                String?
  rolesData            Json?
  requirements         String?
  expectations         String?
  location             String?
  duration             String
  openingsCount        Int
  isActive             Boolean   @default(true)
  // publishStatus controls student visibility for GROUP internships:
  // DRAFT → PENDING_HOD_INPUTS → LIVE (auto on all HODs submitted, or PRTI publishes)
  // SINGLE internships default to LIVE immediately.
  publishStatus        String    @default("LIVE") // DRAFT | PENDING_HOD_INPUTS | LIVE
  applicationDeadline  DateTime?
  quotaPercentages     Json?
  priorityCollege      String?
  priorityCollegeQuota Int?      @default(0)
  requiredDocuments    Json?     // Apply-time docs defined by PRTI (dynamic)
  stipendType          String?   @default("NON_COLLABORATIVE")
  // Per-category stipend amounts for MONETARY internships.
  // Keys map to CollegeCategory enum values: IIT, NIT, IIIT, CENTRAL, STATE, PRIVATE, OTHER
  // Example: { "IIT": 25000, "NIT": 20000, "STATE": 12000, "PRIVATE": 8000 }
  stipendAmounts       Json?     // replaces the single stipendAmount field
  shortlistingRatio    Int?      @default(2)
  preferredColleges    Json?     @default("[]")
  topColleges          Json?     @default("[]")
  seatAllocation       Json?     @default("{}")
  customQuestions      Json?     @default("[]")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  internshipType       String?   @default("STIPEND") // STIPEND, COLLABORATIVE, NON_STIPEND
  internshipMode       String?   @default("SINGLE")  // SINGLE or GROUP
  shortlistLimit       Int?      @default(50)
  // Completion state — set when mentor finalizes the internship
  completionStatus     String?   @default("ONGOING")  // ONGOING | COMPLETED
  completedAt          DateTime?
  completedById        String?   // mentor user id who finalized

  batch              InternshipBatch?                        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  applications       Application[]
  fields             InternshipField[]
  committee          Committee?
  evaluationCriteria InternshipEvaluationCriteria[]
  departmentGroups   InternshipDepartmentGroup[]
  problemStatements  InternshipDepartmentProblemStatement[]
}

model InternshipDepartmentGroup {
  id                String    @id @default(uuid())
  internshipId      String
  department        String
  title             String
  description       String?
  openings          Int       @default(0)
  rolesData         Json?
  skillsRequired    String?
  expectations      String?
  preferredColleges Json?     @default("[]")
  quotaPercentages  Json?
  customQuestions   Json?     @default("[]")
  requiredDocuments Json?     @default("[]") // HOD-configurable docs required after selection
  // Joining letter template (HOD-uploaded; student downloads, fills, uploads back as JOINING_LETTER doc)
  joiningLetterTemplateUrl  String?
  joiningLetterTemplateName String?
  // HOD submission tracking
  hodSubmitted      Boolean   @default(false)
  hodSubmittedAt    DateTime?
  notifiedAt        DateTime? // When PRTI notified this dept's HOD
  internshipType    String?   @default("STIPEND")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  internship        Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  applications      Application[]
  fields            InternshipField[]
  committee         Committee?
  problemStatements InternshipDepartmentProblemStatement[]

  @@unique([internshipId, department])
  @@index([internshipId])
}

// Problem statements submitted by HODs for each department group
model InternshipDepartmentProblemStatement {
  id                    String   @id @default(uuid())
  departmentGroupId     String
  internshipId          String
  title                 String
  description           String?
  requirements          String?
  vacancies             Int      @default(0)
  locations             Json?    @default("[]") // For NON_STIPEND: available locations
  problemStatementNumber Int?                   // Sequential order within dept group
  mentorId              String?                 // Mentor assigned to oversee this PS
  createdBy             String?                 // HOD user ID
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  departmentGroup InternshipDepartmentGroup @relation(fields: [departmentGroupId], references: [id], onDelete: Cascade)
  internship      Internship                @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  mentor          User?                     @relation("PsMentor", fields: [mentorId], references: [id])
  applications    Application[]

  @@index([departmentGroupId])
  @@index([internshipId])
}

model Application {
  id                  String              @id @default(uuid())
  trackingId          String              @unique
  studentId           String
  internshipId        String
  departmentGroupId   String?
  problemStatementId  String?             // For GROUP mode: specific problem statement selected
  fieldId             String?
  status              ApplicationStatus   @default(SUBMITTED)
  score               Float?              @default(0)
  committeeFinalScore Float?              @default(0)
  assignedRole        String?
  stipendAmount       Float?              // Locked at SELECTED: amount based on student's college category
  preferredCircle     String?
  preferredLocation   String?
  sop                 String?
  duration            String?
  startDate           DateTime?
  joiningDate         DateTime?
  endDate             DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  category            InternshipCategory?
  shortlistCategory   String?
  domain              String?
  mentorId            String?
  isHeldSeat          Boolean  @default(false)  // true = PRTI discretionary hold seat
  prtiApproved        Boolean  @default(false)  // PRTI verified this selection; unlocks doc request + hire
  prtiNote            String?                   // PRTI feedback visible to HOD
  questionAnswers     Json?
  scoreBreakdown      Json?
  // Completion flow (set by mentor during "Complete Internship" wizard)
  mentorRemarks            String?
  mentorSatisfactionPercent Int?     // 0-100, mentor's overall satisfaction for this intern
  completionStatus         String?   // PENDING | COMPLETED | INCOMPLETE — set during completion wizard
  completionProcessedAt    DateTime?

  student          StudentProfile                         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship       Internship                             @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup  InternshipDepartmentGroup?             @relation(fields: [departmentGroupId], references: [id])
  problemStatement InternshipDepartmentProblemStatement? @relation(fields: [problemStatementId], references: [id])
  field            InternshipField?                       @relation(fields: [fieldId], references: [id])
  mentor           User?                                  @relation("MentorApps", fields: [mentorId], references: [id])

  documents        Document[]
  stipend          Stipend?
  attendance       Attendance?
  workAssignments  WorkAssignment[]
  evaluationScores EvaluationScore[]
  workLogs         WorkLog[]

  @@unique([studentId, internshipId, assignedRole, fieldId])
  @@index([studentId])
  @@index([internshipId])
  @@index([departmentGroupId])
  @@index([problemStatementId])
  @@index([status])
}

model InternshipField {
  id                String   @id @default(uuid())
  internshipId      String?
  departmentGroupId String?
  fieldMasterId     String?  // links to FieldMaster for NON_STIPEND — stable reference
  fieldName         String
  description       String?
  vacancies         Int      @default(0)
  heldSeats         Int      @default(0)   // reserved seats PRTI can fill by discretion
  locations         Json?    @default("[]")
  specializations   Json?    @default("[]") // e.g. ["Electrical", "Power Systems"]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  internship      Internship?                @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup InternshipDepartmentGroup? @relation(fields: [departmentGroupId], references: [id], onDelete: Cascade)
  fieldMaster     FieldMaster?               @relation(fields: [fieldMasterId], references: [id], onDelete: SetNull)
  applications    Application[]
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  type          String
  url           String?
  fileUrl       String?
  label         String?
  verified      Boolean  @default(false)
  uploadedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model InternshipEvaluationCriteria {
  id           String     @id @default(uuid())
  internshipId String
  question     String
  maxScore     Int        @default(50)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  internship Internship      @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  scores     EvaluationScore[]
}

model EvaluationScore {
  id            String   @id @default(uuid())
  applicationId String
  memberId      String
  role          Role
  questionId    String
  score         Float
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application                  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    InternshipEvaluationCriteria @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, memberId, questionId])
}

model Stipend {
  id             String @id @default(uuid())
  applicationId  String @unique
  panNumber      String
  bankAccount    String
  ifscCode       String
  bankName       String?
  bankBranch     String?
  approvalStatus String @default("SUBMITTED")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Attendance {
  id            String  @id @default(uuid())
  applicationId String  @unique
  daysAttended  Int     @default(0)
  totalDays     Int     @default(0)
  attendanceLog Json?
  mentorReview  String?
  meetsMinimum  Boolean @default(false)
  minimumDays   Int     @default(20)
  fileUrl       String?
  fileName      String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model PortalConfiguration {
  id              String   @id @default("singleton")
  authorizedTotal Int      @default(0)
  departments     Json?    @default("[]")
  // Active offer-letter template ID — Template.id in the template-filling sidecar (see template-filling/).
  // When set, the student's "Download Offer Letter" endpoint POSTs to ${TEMPLATE_FILLING_URL}/api/fill
  // with this templateId and a flat label→value dictionary built from the application.
  offerLetterTemplateId String?
  updatedAt       DateTime @updatedAt
}

model OtpVerification {
  id         String   @id @default(uuid())
  rollNumber String   @unique
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model DocumentConfiguration {
  id        String   @id @default("singleton")
  documents Json
  updatedAt DateTime @updatedAt
}

model Committee {
  id                String    @id @default(uuid())
  internshipId      String?   @unique
  departmentGroupId String?   @unique
  meetLink          String?
  interviewDate     DateTime?
  hodId             String?
  mentorId          String?
  prtiMemberId      String?
  membersData       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  internship      Internship?                @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup InternshipDepartmentGroup? @relation(fields: [departmentGroupId], references: [id], onDelete: Cascade)
}

model aishe_colleges {
  id              Int       @id @default(autoincrement())
  aishe_code      String    @unique @db.VarChar(20)
  college_name    String
  university_name String?
  university_code String?   @db.VarChar(20)
  state_name      String?   @db.VarChar(100)
  district_name   String?   @db.VarChar(100)
  city            String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  college_type    String?   @default("OTHER") @db.VarChar(20)
  management_type String?   @db.VarChar(60)
  programmes      String?
  nirf_rank       Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userEmail String
  details   String?
  target    String?
  createdAt DateTime @default(now())
}

model WorkAssignment {
  id            String    @id @default(uuid())
  applicationId String
  mentorId      String
  studentId     String
  title         String
  description   String
  dueDate       DateTime?
  status        String    @default("PENDING") // PENDING | SUBMITTED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  mentor      User           @relation("MentorWork", fields: [mentorId], references: [id])
  student     StudentProfile @relation("InternWork", fields: [studentId], references: [id])
  submissions TaskSubmission[]
}

model TaskSubmission {
  id               String   @id @default(uuid())
  workAssignmentId String   @unique
  workAssignment   WorkAssignment @relation(fields: [workAssignmentId], references: [id], onDelete: Cascade)
  studentId        String
  submissionDate   DateTime @default(now())
  submissionText   String?
  attachmentUrl    String?
  attachmentType   String?
  status           String   @default("SUBMITTED")
  mentorFeedback   String?
  mentorRating     Int?     // legacy 1-5 star rating, kept for backward compat
  satisfactionPercent Int?  // 0-100 — how satisfactory the assignment is
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([workAssignmentId])
  @@index([studentId])
}

model WorkLog {
  id            String   @id @default(uuid())
  applicationId String
  studentId     String
  date          DateTime @db.Date
  description   String   @db.Text
  hoursWorked   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([applicationId, date])
  @@index([applicationId])
  @@index([studentId])
}

model Certificate {
  id                   String   @id @default(uuid())
  applicationId        String   @unique
  issuedById           String   // mentor user id
  fileUrl              String   // generated PDF path (under uploads/)
  attendancePercent    Int      @default(0)
  satisfactionPercent  Int?     // mentor's overall satisfaction at time of issuance
  remarks              String?
  issuedAt             DateTime @default(now())

  @@index([issuedById])
}
