generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  STUDENT
  HOD
  COMMITTEE_MEMBER
  MENTOR
  CE_PRTI
  ADMIN
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  HIRED
  REJECTED
  SUBMITTED
  HOD_REVIEW
  COMMITTEE_EVALUATION
  CA_APPROVED
  ONGOING
  COMPLETED
}

enum InternshipCategory {
  MONETARY
  CERTIFICATE_ONLY
}

enum CollegeCategory {
  IIT
  NIT
  IIIT
  CENTRAL
  STATE
  PRIVATE
  OTHER
}

enum ScoreCriteria {
  ACADEMIC_MERIT
  SOP_QUALITY
  DISCIPLINE_RELEVANCE
}

enum Decision {
  YES
  NO
}

// ==========================================
// MODELS
// ==========================================
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  role       Role     @default(STUDENT)
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studentProfile StudentProfile?
  mentoredApps   Application[]   @relation("MentorApps")
  workAssignments WorkAssignment[] @relation("MentorWork")
}

model StudentProfile {
  id                String          @id @default(uuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber        String?         @unique
  collegeRollNumber String?
  fullName          String
  phone             String
  dob               DateTime
  address           String
  aadhar            String          @unique
  collegeName       String
  collegeCode       String?
  university        String
  degree            String
  branch            String
  yearOfStudy       Int
  cgpa              Float
  collegeCategory   CollegeCategory
  nirfRanking       Int?
  hasExperience     Boolean         @default(false)
  hasProjects       Boolean         @default(false)
  hasCertifications Boolean         @default(false)
  experienceDesc    String?
  projectsDesc      String?
  skills            String?
  photoUrl          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  applications Application[]
  workAssignments WorkAssignment[] @relation("InternWork")
}

model Internship {
  id                   String    @id @default(uuid())
  title                String
  department           String
  description          String
  roles                String?
  rolesData            Json?
  requirements         String?
  expectations         String?
  location             String?
  duration             String
  openingsCount        Int
  isActive             Boolean   @default(true)
  applicationDeadline  DateTime?
  quotaPercentages     Json?
  priorityCollege      String?
  priorityCollegeQuota Int?      @default(0)
  requiredDocuments    Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  applications Application[]
  committee    Committee?
}

model Application {
  id              String              @id @default(uuid())
  trackingId      String              @unique
  studentId       String
  internshipId    String
  status          ApplicationStatus   @default(SUBMITTED)
  score           Int?                @default(0)
  assignedRole     String?
  preferredCircle  String?
  preferredLocation String?  // User requirement for explicit preferred location
  sop              String?  // User requirement for Statement of Purpose
  duration         String?
  startDate       DateTime?
  joiningDate     DateTime?
  endDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  category        InternshipCategory?
  domain          String?
  mentorId        String?

  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship Internship     @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  mentor     User?          @relation("MentorApps", fields: [mentorId], references: [id])

  documents  Document[]
  shortlist  Shortlist?
  stipend    Stipend?
  attendance Attendance?
  workAssignments WorkAssignment[]

  @@unique([studentId, internshipId])
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  type          String
  url           String?
  fileUrl       String?
  label         String?
  verified      Boolean  @default(false)
  uploadedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Shortlist {
  id            String   @id @default(uuid())
  applicationId String   @unique
  committeeId   String
  
  // Instructor requirements for 3-member tracking
  member1Id     String?
  member1Score  ScoreCriteria?
  member2Id     String?
  member2Score  ScoreCriteria?
  member3Id     String?
  member3Score  ScoreCriteria?
  
  score         Int      @default(0)
  decision      String
  evaluatedAt   DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Stipend {
  id             String @id @default(uuid())
  applicationId  String @unique
  panNumber      String
  bankAccount    String
  ifscCode       String
  bankName       String?
  bankBranch     String?
  approvalStatus String @default("PENDING")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Attendance {
  id            String  @id @default(uuid())
  applicationId String  @unique
  daysAttended  Int     @default(0)
  totalDays     Int     @default(0)
  mentorReview  String?
  meetsMinimum  Boolean @default(false)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model PortalConfiguration {
  id              String   @id @default("singleton")
  authorizedTotal Int      @default(0)
  departments     Json?    @default("[]")
  updatedAt       DateTime @updatedAt
}

model AutomationRule {
  id               String   @id @default(uuid())
  collegeWeight    Float
  cgpaWeight       Float
  experienceWeight Float
  nirfWeight       Float
  updatedAt        DateTime @updatedAt
}

model OtpVerification {
  id         String   @id @default(uuid())
  rollNumber String   @unique
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Committee {
  id            String    @id @default(uuid())
  internshipId  String    @unique
  meetLink      String?
  interviewDate DateTime?
  membersData   Json?     // store array of role+userIds or unstructured {hodId, mentorIds}
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  internship    Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
}

model aishe_colleges {
  id              Int       @id @default(autoincrement())
  aishe_code      String    @unique @db.VarChar(20)
  college_name    String
  university_name String?
  university_code String?   @db.VarChar(20)
  state_name      String?   @db.VarChar(100)
  district_name   String?   @db.VarChar(100)
  city            String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  college_type    String?   @default("OTHER") @db.VarChar(20)
  management_type String?   @db.VarChar(60)
  programmes      String?
  nirf_rank       Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userEmail String
  details   String?
  target    String?
  createdAt DateTime @default(now())
}

model WorkAssignment {
  id            String   @id @default(uuid())
  applicationId String
  mentorId      String
  studentId     String
  title         String
  description   String
  dueDate       DateTime?
  status        String   @default("PENDING") // PENDING, COMPLETED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  mentor        User        @relation("MentorWork", fields: [mentorId], references: [id])
  student       StudentProfile @relation("InternWork", fields: [studentId], references: [id])
}
