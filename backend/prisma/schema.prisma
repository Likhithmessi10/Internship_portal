generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
  COMPLETED
  CERTIFIED
}

enum CollegeCategory {
  IIT
  NIT
  IIIT
  CENTRAL
  STATE_UNIV
  DEEMED
  AUTONOMOUS
  COLLEGE
  INSTITUTE
  OTHER
}

enum DocumentType {
  RESUME
  PRINCIPAL_LETTER
  HOD_LETTER
  NOC_LETTER
  MARKSHEET
  PASSPORT_PHOTO
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(ADMIN) // Default to ADMIN now since students are passwordless

  studentProfile StudentProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentProfile {
  id         String @id @default(uuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber        String? @unique // Assigned manually by Admin during hiring
  collegeRollNumber String? // Actual roll number from candidate's institution

  // Personal Details
  fullName String
  phone    String
  dob      DateTime
  address  String
  aadhar   String   @unique

  // Educational Details
  collegeName     String
  collegeCode     String?
  university      String
  degree          String
  branch          String
  yearOfStudy     Int
  cgpa            Float
  collegeCategory CollegeCategory
  nirfRanking     Int?

  // Optional Details
  hasExperience     Boolean @default(false)
  hasProjects       Boolean @default(false)
  hasCertifications Boolean @default(false)
  experienceDesc    String?
  projectsDesc      String?
  skills            String?
  photoUrl          String? // NEW PROFILE PHOTO URL

  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Internship {
  id                  String    @id @default(uuid())
  title               String
  department          String
  description         String
  roles               String? // Legacy string field (kept to not break existing)
  rolesData           Json?     @db.JsonB // New structured array [{name, openings, hired}]
  requirements        String? // Candidate requirements
  expectations        String? // What interns will learn/do
  location            String
  duration            String // e.g., "6 Months", "10 Weeks"
  openingsCount       Int
  isActive            Boolean   @default(true)
  applicationDeadline DateTime?
  quotaPercentages    Json?     @db.JsonB
  priorityCollege     String?
  priorityCollegeQuota Int?      @default(0)
  requiredDocuments   Json?     @db.JsonB // Array of required document types

  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id           String            @id @default(uuid())
  trackingId   String            @unique // Human readable tracking code
  studentId    String
  internshipId String
  status       ApplicationStatus @default(PENDING)
  score        Float             @default(0.0) // Automated System Score
  assignedRole String? // The role they were hired for

  preferredCircle String?
  duration        String?
  startDate       String?
  joiningDate     DateTime?
  endDate         DateTime?

  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship Internship     @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  documents  Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, internshipId])
}

model Document {
  id            String       @id @default(uuid())
  applicationId String
  type          String       // Support dynamic document labels
  url           String // S3 or local path

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
}

model AutomationRule {
  id               String   @id @default(uuid())
  collegeWeight    Float    @default(40.0)
  cgpaWeight       Float    @default(30.0)
  experienceWeight Float    @default(20.0)
  nirfWeight       Float    @default(10.0)
  updatedAt        DateTime @updatedAt
}

model PortalConfiguration {
  id              String   @id @default("singleton")
  authorizedTotal Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model OtpVerification {
  id         String   @id @default(uuid())
  rollNumber String   @unique
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AisheCollege {
  id              Int       @id @default(autoincrement())
  aishe_code      String    @unique @db.VarChar(20)
  college_name    String
  university_name String?
  university_code String?   @db.VarChar(20)
  state_name      String?   @db.VarChar(100)
  district_name   String?   @db.VarChar(100)
  city            String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  college_type    String?   @default("OTHER") @db.VarChar(20)
  management_type String?   @db.VarChar(60)
  programmes      String?
  nirf_rank       Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz
  updated_at      DateTime? @default(now()) @db.Timestamptz

  @@map("aishe_colleges")
}
