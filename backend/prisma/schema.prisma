generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  STUDENT
  HOD
  COMMITTEE_MEMBER
  MENTOR
  CE_PRTI
  ADMIN
}

enum ApplicationStatus {
  SUBMITTED
  SHORTLISTED
  UNDER_COMMITTEE_REVIEW
  APPROVED
  REJECTED
  WAITLISTED
  HIRED
  ONGOING
  COMPLETED
}

enum InternshipCategory {
  MONETARY
  CERTIFICATE_ONLY
}

enum CollegeCategory {
  IIT
  NIT
  IIIT
  CENTRAL
  STATE
  PRIVATE
  OTHER
}

enum ScoreCriteria {
  ACADEMIC_MERIT
  SOP_QUALITY
  DISCIPLINE_RELEVANCE
}

enum Decision {
  YES
  NO
}

// ==========================================
// MODELS
// ==========================================
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String?
  role       Role     @default(STUDENT)
  department String?
  phone      String?  @map("phone_number")
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studentProfile StudentProfile?
  mentoredApps   Application[]   @relation("MentorApps")
  workAssignments WorkAssignment[] @relation("MentorWork")
}

model StudentProfile {
  id                String          @id @default(uuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber        String?         @unique
  collegeRollNumber String?
  fullName          String
  phone             String
  dob               DateTime
  address           String
  aadhaarNumber     String          @unique @map("aadhar")
  collegeName       String
  collegeCode       String?
  university        String
  degree            String
  branch            String
  yearOfStudy       Int
  cgpa              Float
  collegeCategory   CollegeCategory
  nirfRanking       Int?
  hasExperience     Boolean         @default(false)
  hasProjects       Boolean         @default(false)
  hasCertifications Boolean         @default(false)
  experienceDesc    String?
  projectsDesc      String?
  skills            String?
  photoUrl          String?
  linkedinUrl       String?
  githubUrl         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  applications Application[]
  workAssignments WorkAssignment[] @relation("InternWork")

  @@index([userId])
  @@index([collegeName])
}

model InternshipBatch {
  id          String       @id @default(uuid())
  title       String       // e.g. "Summer Internships 2026"
  description String?
  createdBy   String?      // PRTI member email/id
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  internships Internship[]
}

model Internship {
  id                   String    @id @default(uuid())
  batchId              String?   // Link to master folder
  title                String
  department           String
  description          String
  roles                String?
  rolesData            Json?
  requirements         String?
  expectations         String?
  location             String?
  duration             String
  openingsCount        Int
  isActive             Boolean   @default(true)
  applicationDeadline  DateTime?
  quotaPercentages     Json?
  priorityCollege      String?
  priorityCollegeQuota Int?      @default(0)
  requiredDocuments    Json?
  stipendType          String?   @default("NON_COLLABORATIVE") // COLLABORATIVE or NON_COLLABORATIVE
  stipendAmount        Float?    // Amount in INR (optional, for collaborative)
  shortlistingRatio    Int?      @default(2)
  preferredColleges    Json?     @default("[]")
  topColleges          Json?     @default("[]")
  seatAllocation       Json?     @default("{}")
  customQuestions      Json?     @default("[]")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  internshipType       String?   @default("STIPEND") // STIPEND, COLLABORATIVE, NON_STIPEND
  internshipMode       String?   @default("SINGLE") // SINGLE or GROUP
  shortlistLimit       Int?      @default(50)

  batch        InternshipBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  applications Application[]
  fields       InternshipField[]
  committee    Committee?
  evaluationCriteria InternshipEvaluationCriteria[]
  departmentGroups InternshipDepartmentGroup[]
}

model InternshipDepartmentGroup {
  id                String    @id @default(uuid())
  internshipId      String
  department        String
  title             String    // e.g. "Electrical Engineering Trainee"
  description       String?
  openings          Int       @default(0)
  rolesData         Json?     // [{name, openings}]
  skillsRequired    String?   // comma-separated skills
  expectations      String?
  preferredColleges Json?     @default("[]")
  quotaPercentages  Json?     // {preferred, premier, normal}
  problemStatements Json?     @default("[]")
  customQuestions   Json?     @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  internshipType    String?   @default("STIPEND")
  internship        Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  applications      Application[]
  fields            InternshipField[]
  committee         Committee?

  @@unique([internshipId, department])
  @@index([internshipId])
}

model Application {
  id              String              @id @default(uuid())
  trackingId      String              @unique
  studentId       String
  internshipId    String
  departmentGroupId String?           // For GROUP mode: links to specific department group
  fieldId         String?           // For NON_STIPEND mode: links to specific field
  status          ApplicationStatus   @default(SUBMITTED)
  resumeMatchScore Float?             @default(0)
  isResumeProcessed Boolean           @default(false)
  score           Float?              @default(0)
  committeeFinalScore Float?          @default(0)
  assignedRole     String?
  preferredCircle  String?
  preferredLocation String?  // User requirement for explicit preferred location
  sop              String?  // User requirement for Statement of Purpose
  duration         String?
  startDate       DateTime?
  joiningDate     DateTime?
  endDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  category        InternshipCategory?
  shortlistCategory String?
  domain          String?
  mentorId        String?
  questionAnswers Json?
  scoreBreakdown  Json?
  parsedResumeText String?
  extractedSkills  Json?
  extractedProjects Json?

  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internship Internship     @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup InternshipDepartmentGroup? @relation(fields: [departmentGroupId], references: [id])
  field          InternshipField?           @relation(fields: [fieldId], references: [id])
  mentor     User?          @relation("MentorApps", fields: [mentorId], references: [id])

  documents  Document[]
  stipend    Stipend?
  attendance Attendance?
  workAssignments WorkAssignment[]
  evaluationScores EvaluationScore[]

  @@unique([studentId, internshipId, assignedRole, fieldId])
  @@index([studentId])
  @@index([internshipId])
  @@index([departmentGroupId])
  @@index([status])
}

model InternshipField {
  id                String   @id @default(uuid())
  internshipId      String?
  departmentGroupId String?
  fieldName         String
  description       String?
  vacancies         Int      @default(0)
  locations         Json?    @default("[]") // Array of strings
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  internship        Internship? @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup   InternshipDepartmentGroup? @relation(fields: [departmentGroupId], references: [id], onDelete: Cascade)
  applications      Application[]
}

model Document {
  id            String   @id @default(uuid())
  applicationId String
  type          String
  url           String?
  fileUrl       String?
  label         String?
  verified      Boolean  @default(false)
  uploadedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}


model InternshipEvaluationCriteria {
  id           String     @id @default(uuid())
  internshipId String
  question     String
  maxScore     Int        @default(50)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  scores       EvaluationScore[]
}

model EvaluationScore {
  id            String   @id @default(uuid())
  applicationId String
  memberId      String
  role          Role
  questionId    String
  score         Float
  comments      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question      InternshipEvaluationCriteria @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, memberId, questionId])
}


model Stipend {
  id             String @id @default(uuid())
  applicationId  String @unique
  panNumber      String
  bankAccount    String
  ifscCode       String
  bankName       String?
  bankBranch     String?
  approvalStatus String @default("SUBMITTED")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Attendance {
  id            String  @id @default(uuid())
  applicationId String  @unique
  daysAttended  Int     @default(0)
  totalDays     Int     @default(0)
  attendanceLog Json?   // [{date: "2026-03-15", present: true, hours: 8, markedAt: "..."}]
  mentorReview  String?
  meetsMinimum  Boolean @default(false)
  minimumDays   Int     @default(20)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model PortalConfiguration {
  id              String   @id @default("singleton")
  authorizedTotal Int      @default(0)
  departments     Json?    @default("[]")
  updatedAt       DateTime @updatedAt
}


model OtpVerification {
  id         String   @id @default(uuid())
  rollNumber String   @unique
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model DocumentConfiguration {
  id        String @id @default("singleton")
  documents Json   // [{id, label, type, mandatory}]
  updatedAt DateTime @updatedAt
}

model Committee {
  id                String    @id @default(uuid())
  internshipId      String?   @unique // For SINGLE mode
  departmentGroupId String?   @unique // For GROUP mode
  meetLink          String?
  interviewDate     DateTime?
  
  // Committee structure:
  // Member 1 (Permanent): HOD of the department
  // Member 2 (Assigned): Mentor (assigned by HOD, same department)
  // Member 3 (Editable): PRTI Representative (selected by PRTI member)
  hodId         String?   // Permanent - HOD of department
  mentorId      String?   // Assigned by HOD
  prtiMemberId  String?   // Editable by PRTI
  
  membersData   Json?     // Store additional member details
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  internship        Internship? @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  departmentGroup   InternshipDepartmentGroup? @relation(fields: [departmentGroupId], references: [id], onDelete: Cascade)
}

model aishe_colleges {
  id              Int       @id @default(autoincrement())
  aishe_code      String    @unique @db.VarChar(20)
  college_name    String
  university_name String?
  university_code String?   @db.VarChar(20)
  state_name      String?   @db.VarChar(100)
  district_name   String?   @db.VarChar(100)
  city            String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  college_type    String?   @default("OTHER") @db.VarChar(20)
  management_type String?   @db.VarChar(60)
  programmes      String?
  nirf_rank       Int?
  is_active       Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userEmail String
  details   String?
  target    String?
  createdAt DateTime @default(now())
}

model WorkAssignment {
  id            String   @id @default(uuid())
  applicationId String
  mentorId      String
  studentId     String
  title         String
  description   String
  dueDate       DateTime?
  status        String   @default("SUBMITTED") // PENDING -> SUBMITTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  mentor        User        @relation("MentorWork", fields: [mentorId], references: [id])
  student       StudentProfile @relation("InternWork", fields: [studentId], references: [id])
  submissions   TaskSubmission[]
}

model TaskSubmission {
  id              String   @id @default(uuid())
  workAssignmentId String @unique
  workAssignment  WorkAssignment @relation(fields: [workAssignmentId], references: [id], onDelete: Cascade)
  
  studentId       String
  submissionDate  DateTime @default(now())
  submissionText  String?
  attachmentUrl   String?
  attachmentType  String?  // PDF, DOC, ZIP, etc.
  
  status          String   @default("SUBMITTED") // SUBMITTED
  mentorFeedback  String?
  mentorRating    Int?     // 1-5 scale
  reviewedAt      DateTime?
  reviewedBy      String?
  
  createdAt       DateTime @updatedAt
  updatedAt       DateTime @updatedAt

  @@index([workAssignmentId])
  @@index([studentId])
}

enum JobStatus {
  PENDING
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

model Job {
  id          String    @id @default(uuid())
  type        String    // RESUME_MATCH_SCORE
  status      JobStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  fingerprint String?   // Remove @unique to allow repeat runs
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status])
  @@index([createdAt])
}
