# ── Docker Compose secrets — EXAMPLE (safe to commit) ───────────────────────
# Copy to .env and fill in real values before deploying.
# Generate secrets: openssl rand -hex 32

POSTGRES_DB=aptransco
POSTGRES_USER=aptransco
POSTGRES_PASSWORD=

JWT_SECRET=
JWT_REFRESH_SECRET=

# Shared token between backend ↔ template-filling sidecar
SIDECAR_TOKEN=

EMAIL_API_KEY=
