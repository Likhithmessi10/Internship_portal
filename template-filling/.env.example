# Shared PostgreSQL database with the main APTRANSCO portal, but in a
# DEDICATED Postgres schema so the two Prisma projects don't trample each
# other's tables. The `template_filling` schema is created automatically.
DATABASE_URL="postgresql://postgres:2912@localhost:5433/aptransco?schema=template_filling"

# Port this Next.js sidecar runs on. The main backend's offerLetterService.js
# calls this via TEMPLATE_FILLING_URL.
PORT=3100
