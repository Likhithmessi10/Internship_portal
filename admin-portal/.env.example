# ============================================================
# Admin Portal — Environment Variables
# Copy this file to .env and fill in YOUR_SERVER_IP
# ============================================================

# Backend API URL (must end with /api/v1)
VITE_API_URL=http://YOUR_SERVER_IP:5001/api/v1

# Backend base URL for media/files (no /api/v1, no trailing slash)
VITE_API_BASE_URL=http://YOUR_SERVER_IP:5001

# Feature Flags
# false = learning/non-monetary mode (default)
# true  = enables paid/collaborative internship workflow
VITE_MONETARY_ENABLED=false
